# Discord OAuth2 (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=twoje_client_id
DISCORD_CLIENT_SECRET=twoj_client_secret
DISCORD_CALLBACK_URL=http://localhost:3001/auth/discord/callback

# Discord Bot Token (ten sam lub inny bot na Twoim serwerze)
DISCORD_BOT_TOKEN=twoj_bot_token

# Session secret - zmień na losowy string w produkcji!
SESSION_SECRET=super-tajny-klucz-zmien-mnie

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Port backendu
PORT=3001

# Środowisko (ustaw "production" na hostingu!)
NODE_ENV=development
